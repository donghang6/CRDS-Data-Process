   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# 02 - 吸收光谱与基线处理\\n\",\n",
    "    \"\\n\",\n",
    "    \"本 Notebook 用于:\\n\",\n",
    "    \"- 从衰荡时间计算吸收系数\\n\",\n",
    "    \"- 基线拟合与扣除\\n\",\n",
    "    \"- 可视化吸收光谱\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from crds_process.config import load_config\\n\",\n",
    "    \"from crds_process.io.readers import load_scan_directory\\n\",\n",
    "    \"from crds_process.ringdown.processing import process_all_scans\\n\",\n",
    "    \"from crds_process.absorption.coefficients import ringdown_results_to_spectrum\\n\",\n",
    "    \"from crds_process.baseline.fitting import subtract_baseline\\n\",\n",
    "    \"from crds_process.visualization.plots import plot_absorption_spectrum\\n\",\n",
    "    \"\\n\",\n",
    "    \"cfg = load_config('../config/default.yaml')\\n\",\n",
    "    \"scans = load_scan_directory('../data/raw')\\n\",\n",
    "    \"rd_results = process_all_scans(scans)\\n\",\n",
    "    \"spectrum_df = ringdown_results_to_spectrum(rd_results, tau0_us=cfg.absorption.tau0_us)\\n\",\n",
    "    \"spectrum_df.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 基线扣除\\n\",\n",
    "    \"spectrum_df = subtract_baseline(\\n\",\n",
    "    \"    spectrum_df,\\n\",\n",
    "    \"    regions=cfg.baseline.regions,\\n\",\n",
    "    \"    method=cfg.baseline.method,\\n\",\n",
    "    \"    poly_order=cfg.baseline.poly_order,\\n\",\n",
    "    \")\\n\",\n",
    "    \"fig = plot_absorption_spectrum(spectrum_df)\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
