    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# 01 - 衰荡时间数据探索\\n\",\n",
    "    \"\\n\",\n",
    "    \"本 Notebook 用于探索原始衰荡数据:\\n\",\n",
    "    \"- 读取原始数据文件\\n\",\n",
    "    \"- 查看衰荡时间分布\\n\",\n",
    "    \"- 测试离群值过滤效果\\n\",\n",
    "    \"- 绘制衰荡时间光谱\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"from crds_process.io.readers import load_scan_directory, scans_to_dataframe\\n\",\n",
    "    \"from crds_process.ringdown.filtering import filter_ringdown_times\\n\",\n",
    "    \"from crds_process.visualization.plots import plot_ringdown_histogram, plot_tau_spectrum\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 修改为你的数据目录\\n\",\n",
    "    \"DATA_DIR = Path('../data/raw')\\n\",\n",
    "    \"scans = load_scan_directory(DATA_DIR)\\n\",\n",
    "    \"print(f'读取了 {len(scans)} 个扫描点')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 查看单个扫描点的衰荡时间分布\\n\",\n",
    "    \"scan = scans[0]\\n\",\n",
    "    \"tau_filtered = filter_ringdown_times(scan.tau, method='sigma_clip', sigma=3.0)\\n\",\n",
    "    \"fig = plot_ringdown_histogram(scan.tau, tau_filtered, wavenumber=scan.meta.wavenumber)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 汇总统计\\n\",\n",
    "    \"df = scans_to_dataframe(scans)\\n\",\n",
    "    \"df.head()\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
