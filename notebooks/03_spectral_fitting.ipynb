    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# 03 - MATS 光谱拟合\\n\",\n",
    "    \"\\n\",\n",
    "    \"本 Notebook 用于:\\n\",\n",
    "    \"- 将处理后的吸收光谱导入 MATS\\n\",\n",
    "    \"- 配置拟合参数\\n\",\n",
    "    \"- 执行多光谱拟合\\n\",\n",
    "    \"- 提取线强、展宽系数等光谱参数\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from crds_process.config import load_config\\n\",\n",
    "    \"from crds_process.spectral.mats_wrapper import prepare_mats_input, run_mats_fit\\n\",\n",
    "    \"from crds_process.visualization.plots import plot_fit_result\\n\",\n",
    "    \"\\n\",\n",
    "    \"cfg = load_config('../config/default.yaml')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 读取步骤2保存的光谱\\n\",\n",
    "    \"spectrum_df = pd.read_csv('../output/results/spectrum.csv')\\n\",\n",
    "    \"spectrum_df.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 准备 MATS 输入并拟合\\n\",\n",
    "    \"mats_input = prepare_mats_input(spectrum_df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fit_result = run_mats_fit(\\n\",\n",
    "    \"    mats_input,\\n\",\n",
    "    \"    temperature_K=cfg.gas.temperature_K,\\n\",\n",
    "    \"    pressure_torr=cfg.gas.pressure_torr,\\n\",\n",
    "    \"    species=cfg.gas.species,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('拟合参数:')\\n\",\n",
    "    \"for k, v in fit_result.parameters.items():\\n\",\n",
    "    \"    err = fit_result.uncertainties.get(k, 0)\\n\",\n",
    "    \"    print(f'  {k}: {v:.6e} ± {err:.6e}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 绘制拟合结果\\n\",\n",
    "    \"if fit_result.fitted_spectrum is not None:\\n\",\n",
    "    \"    fig = plot_fit_result(\\n\",\n",
    "    \"        spectrum_df['wavenumber'].values,\\n\",\n",
    "    \"        spectrum_df['alpha_corrected'].values,\\n\",\n",
    "    \"        fit_result.fitted_spectrum,\\n\",\n",
    "    \"        residuals=fit_result.residuals,\\n\",\n",
    "    \"    )\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
